{
  "title": "Homelab Overview",
  "uid": "homelab-overview",
  "tags": ["homelab", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Services",
      "type": "stat",
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "label_replace(label_replace(probe_success{job=\"blackbox_http\"}, \"service\", \"$1\", \"instance\", \".*://([^:/]+).*\"), \"service\", \"plex\", \"service\", \"host.docker.internal\")",
          "legendFormat": "{{service}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": true},
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "wideLayout": false,
        "percentChangeColorMode": "standard"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      }
    },
    {
      "id": 10,
      "title": "CPU",
      "type": "stat",
      "gridPos": {"h": 5, "w": 5, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "100 - (avg(irate(node_cpu_seconds_total{job=\"node_mac\",mode=\"idle\"}[5m])) * 100)"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "displayName": " ",
          "min": 0, "max": 100,
          "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 60},
            {"color": "red", "value": 85}
          ]}
        }
      }
    },
    {
      "id": 11,
      "title": "RAM",
      "type": "stat",
      "gridPos": {"h": 5, "w": 5, "x": 5, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "(node_memory_active_bytes{job=\"node_mac\"} + node_memory_wired_bytes{job=\"node_mac\"} + node_memory_compressed_bytes{job=\"node_mac\"}) / node_memory_total_bytes{job=\"node_mac\"} * 100"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "displayName": " ",
          "min": 0, "max": 100,
          "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 70},
            {"color": "red", "value": 90}
          ]}
        }
      }
    },
    {
      "id": 12,
      "title": "Disk /",
      "type": "stat",
      "gridPos": {"h": 5, "w": 5, "x": 10, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "(1 - node_filesystem_avail_bytes{job=\"node_mac\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"node_mac\",mountpoint=\"/\"}) * 100"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "displayName": " ",
          "min": 0, "max": 100,
          "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 75},
            {"color": "red", "value": 90}
          ]}
        }
      }
    },
    {
      "id": 13,
      "title": "Load 1m",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 15, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "node_load1{job=\"node_mac\"}"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "displayName": " ",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 4},
            {"color": "red", "value": 8}
          ]}
        }
      }
    },
    {
      "id": 14,
      "title": "Uptime",
      "type": "stat",
      "gridPos": {"h": 5, "w": 5, "x": 19, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "time() - node_boot_time_seconds{job=\"node_mac\"}"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {"defaults": {"unit": "s", "displayName": " ", "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 15,
      "title": "CPU cores",
      "type": "stat",
      "gridPos": {"h": 3, "w": 5, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "count(count by (cpu) (node_cpu_seconds_total{job=\"node_mac\"}))"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {"defaults": {"displayName": " ", "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 16,
      "title": "RAM used",
      "type": "stat",
      "gridPos": {"h": 3, "w": 5, "x": 5, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "node_memory_active_bytes{job=\"node_mac\"} + node_memory_wired_bytes{job=\"node_mac\"} + node_memory_compressed_bytes{job=\"node_mac\"}"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {"defaults": {"unit": "bytes", "displayName": " ", "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 17,
      "title": "Disk used",
      "type": "stat",
      "gridPos": {"h": 3, "w": 5, "x": 10, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "node_filesystem_size_bytes{job=\"node_mac\",mountpoint=\"/\"} - node_filesystem_avail_bytes{job=\"node_mac\",mountpoint=\"/\"}"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {"defaults": {"unit": "bytes", "displayName": " ", "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 18,
      "title": "NAS free",
      "type": "stat",
      "gridPos": {"h": 3, "w": 9, "x": 15, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "node_filesystem_avail_bytes{job=\"node_mac\",mountpoint=\"/Users/pupca/media\"}"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {"defaults": {"unit": "bytes", "displayName": " ", "color": {"mode": "fixed", "fixedColor": "green"}}}
    },
    {
      "id": 50,
      "title": "Docker VM CPU",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])) / max(machine_cpu_cores) * 100"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "decimals": 1,
          "displayName": " ",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 60},
            {"color": "red", "value": 85}
          ]}
        }
      }
    },
    {
      "id": 51,
      "title": "Docker VM RAM",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum(container_memory_working_set_bytes{name!=\"\"}) / max(machine_memory_bytes) * 100"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "decimals": 1,
          "displayName": " ",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 70},
            {"color": "red", "value": 90}
          ]}
        }
      }
    },
    {
      "id": 52,
      "title": "VM RAM used / allocated",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(container_memory_working_set_bytes{name!=\"\"})", "legendFormat": "used"},
        {"refId": "B", "expr": "max(machine_memory_bytes)", "legendFormat": "allocated"}
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 53,
      "title": "VM cores",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "max(machine_cpu_cores)"}],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "wideLayout": true
      },
      "fieldConfig": {"defaults": {"displayName": " ", "color": {"mode": "fixed", "fixedColor": "blue"}}}
    },
    {
      "id": 20,
      "title": "Load average",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 17},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "node_load1{job=\"node_mac\"}", "legendFormat": "1m"},
        {"refId": "B", "expr": "node_load5{job=\"node_mac\"}", "legendFormat": "5m"},
        {"refId": "C", "expr": "node_load15{job=\"node_mac\"}", "legendFormat": "15m"}
      ],
      "fieldConfig": {"defaults": {"custom": {"fillOpacity": 15, "lineWidth": 2, "gradientMode": "opacity"}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}}
    },
    {
      "id": 21,
      "title": "Service response time",
      "type": "bargauge",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 17},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "label_replace(label_replace(probe_duration_seconds{job=\"blackbox_http\"}, \"service\", \"$1\", \"instance\", \".*://([^:/]+).*\"), \"service\", \"plex\", \"service\", \"host.docker.internal\")",
          "legendFormat": "{{service}}",
          "instant": true
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "minVizWidth": 0,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "red", "value": 2}
          ]}
        }
      }
    },
    {
      "id": 30,
      "title": "Container CPU",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])) * 100", "legendFormat": "{{name}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"fillOpacity": 10, "lineWidth": 1, "gradientMode": "opacity"}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 31,
      "title": "Container RAM",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (name) (container_memory_working_set_bytes{name!=\"\"})", "legendFormat": "{{name}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"fillOpacity": 10, "stacking": {"mode": "normal"}, "lineWidth": 1}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "id": 40,
      "title": "Containers",
      "type": "table",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "CPU", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[5m])) * 100", "instant": true, "format": "table"},
        {"refId": "RAM", "expr": "sum by (name) (container_memory_working_set_bytes{name!=\"\"})", "instant": true, "format": "table"},
        {"refId": "RX", "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[5m]))", "instant": true, "format": "table"},
        {"refId": "TX", "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!=\"\"}[5m]))", "instant": true, "format": "table"}
      ],
      "transformations": [
        {"id": "joinByField", "options": {"byField": "name", "mode": "outer"}},
        {"id": "organize", "options": {
          "excludeByName": {"Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true},
          "renameByName": {
            "name": "Container",
            "Value #CPU": "CPU %",
            "Value #RAM": "RAM",
            "Value #RX": "Net RX /s",
            "Value #TX": "Net TX /s"
          }
        }}
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {"matcher": {"id": "byName", "options": "CPU %"}, "properties": [
            {"id": "unit", "value": "percent"},
            {"id": "decimals", "value": 2},
            {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 20}, {"color": "red", "value": 60}]}}
          ]},
          {"matcher": {"id": "byName", "options": "RAM"}, "properties": [
            {"id": "unit", "value": "bytes"},
            {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
            {"id": "thresholds", "value": {"mode": "absolute", "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500000000},
              {"color": "orange", "value": 1000000000},
              {"color": "red", "value": 2000000000}
            ]}}
          ]},
          {"matcher": {"id": "byName", "options": "Net RX /s"}, "properties": [{"id": "unit", "value": "Bps"}]},
          {"matcher": {"id": "byName", "options": "Net TX /s"}, "properties": [{"id": "unit", "value": "Bps"}]}
        ]
      },
      "options": {"sortBy": [{"displayName": "RAM", "desc": true}], "footer": {"show": false}, "cellHeight": "sm"}
    }
  ]
}
